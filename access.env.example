# Copy this file to access.env and add your local credentials.
# access.env is ignored by git.

# Gemini / Google AI Studio API key.
# Either GEMINI_API_KEY or GOOGLE_API_KEY will work; GEMINI_API_KEY is preferred here.
GEMINI_API_KEY=PASTE_YOUR_GEMINI_API_KEY_HERE

# Optional Gemini model overrides.
# GEMINI_ANALYSIS_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-3-pro-image

# Optional runtime settings.
# HOST=127.0.0.1
# PORT=5173
